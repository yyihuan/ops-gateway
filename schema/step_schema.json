{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.devops/schemas/step_schema.json",
  "title": "Auditable Execution Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "plan_title",
    "target",
    "steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
    },
    "plan_title": {
      "type": "string",
      "minLength": 3
    },
    "description": {
      "type": "string"
    },
    "operator": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host",
        "os"
      ],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1
        },
        "os": {
          "type": "string",
          "minLength": 1
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "task_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$"
        }
      },
      "additionalProperties": true
    },
    "remote_sync": {
      "$ref": "#/$defs/remoteSync"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "run"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "review_note": {
          "type": "string",
          "minLength": 3
        },
        "effects": {
          "$ref": "#/$defs/effects"
        },
        "run": {
          "type": "string",
          "minLength": 1
        },
        "cwd": {
          "type": "string"
        },
        "shell": {
          "type": "string",
          "default": "/bin/bash"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 86400,
          "default": 1800
        },
        "allow_failure": {
          "type": "boolean",
          "default": false
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "read_only": {
          "type": "boolean"
        },
        "requires_root": {
          "type": "boolean"
        },
        "reads_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "writes_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "network_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "service_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "summary"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "approval_hint": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "backup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "location": {
          "type": "string",
          "minLength": 1
        },
        "paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "write-paths",
              "etc-if-touched"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "goal",
        "reason",
        "risk",
        "pre_checks",
        "commands",
        "post_checks",
        "rollback"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{1,63}$"
        },
        "title": {
          "type": "string",
          "minLength": 3
        },
        "goal": {
          "type": "string",
          "minLength": 3
        },
        "reason": {
          "type": "string",
          "minLength": 3
        },
        "notes": {
          "type": "string"
        },
        "backup": {
          "$ref": "#/$defs/backup"
        },
        "risk": {
          "$ref": "#/$defs/risk"
        },
        "pre_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command"
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/command"
          }
        },
        "post_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command"
          }
        },
        "rollback": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command"
          }
        }
      }
    },
    "remoteSync": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "target"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "target": {
          "type": "string",
          "pattern": "^.+:.+$"
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "phases": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "step_end",
              "plan_end"
            ]
          },
          "uniqueItems": true,
          "default": [
            "plan_end"
          ]
        },
        "rsync_options": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "-az"
          ]
        },
        "ssh_options": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
